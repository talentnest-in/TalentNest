DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/talentnest?schema=public"

DB_USER="postgres"
DB_PASSWORD="your_db_password"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="talentnest"

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX"
COOKIE_SECRET="REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX"

# JWT expiry (e.g. 15m, 7d, 1h)
JWT_EXPIRES_IN="7d"
